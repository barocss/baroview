{
  "name": "baroview",
  "version": "0.1.1",
  "description": "URL-based document viewer web component",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/baroview.umd.cjs",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/baroview.umd.cjs",
    "module": "./dist/baroview.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/baroview.js",
        "require": "./dist/baroview.umd.cjs",
        "default": "./dist/baroview.js"
      }
    },
    "files": [
      "dist"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc",
    "preview": "vite preview"
  },
  "dependencies": {
    "baroview-core": "workspace:*",
    "marked": "^11.0.0",
    "pdfjs-dist": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
